# =============================================================================
# SMTP Configuration - Copy to .env and fill in your values
# DO NOT commit .env to version control
# =============================================================================

# SMTP Server
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Authentication
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=yourapppasswordwithoutspaces

# Sender address (optional, defaults to SMTP_USERNAME)
SMTP_FROM=your_email@gmail.com

# Security
SMTP_STARTTLS=true
SMTP_SSL=false
SMTP_TIMEOUT=30

# Email report settings
EMAIL_SUBJECT_PREFIX=LinkedIn JD 匹配报告